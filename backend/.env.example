# AWS Configuration
AWS_REGION=us-east-1
AWS_PROFILE=default
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0

# Bedrock Guardrails (optional — create in Bedrock console, enable PII filter + prompt attack detection)
# BEDROCK_GUARDRAIL_ID=your-guardrail-id
# BEDROCK_GUARDRAIL_VERSION=1

# ── Aurora PostgreSQL Database ──────────────────────────────────────────────
# Option 1: Secrets Manager (recommended — stores host/port/user/password)
# DB_SECRET_NAME=dataops-agent/aurora-credentials

# Option 2: Direct env vars
DB_HOST=your-cluster.cluster-xxxxxxxxxxxx.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-password

# Aurora cluster/instance identifiers (for CloudWatch metrics + RDS API calls)
AURORA_CLUSTER_ID=your-aurora-cluster-id
AURORA_INSTANCE_ID=your-aurora-instance-id

# SSL/TLS — Aurora requires SSL; use verify-full with the RDS CA bundle
DB_SSLMODE=verify-full
# Download from: https://truststore.pki.rds.amazonaws.com/global/global-bundle.pem
# Or run: curl -o rds-global-bundle.pem https://truststore.pki.rds.amazonaws.com/global/global-bundle.pem
DB_SSLROOTCERT=rds-global-bundle.pem

# App Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
